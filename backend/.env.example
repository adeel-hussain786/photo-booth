# Copy this file to .env and fill in real values.
# On Render, set these in the dashboard under Environment instead of a file.

# Contact-form email (Gmail app password)
EMAIL=your-gmail@gmail.com
PASSWORD=your-gmail-app-password

# Server
PORT=5000
NODE_ENV=production

# Where the SQLite database file lives (use the persistent disk in production)
DB_PATH=/var/data/memorify.db

# Your frontend's public URL(s), comma-separated. Locks down CORS.
FRONTEND_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Cloudinary (private image/video storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
